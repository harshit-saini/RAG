APP_NAME="Vectorless RAG API"
ENV="dev"

MONGO_URI="mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
MONGO_DB="rag"
MONGO_COLLECTION_DOCS="documents"
MONGO_COLLECTION_CHUNKS="chunks"

OPENSEARCH_HOST="https://search-your-domain.us-east-1.es.amazonaws.com"
OPENSEARCH_INDEX="rag_chunks"
OPENSEARCH_USER=""
OPENSEARCH_PASSWORD=""
OPENSEARCH_VERIFY_CERTS="true"

CHUNK_SIZE_CHARS=1200
CHUNK_OVERLAP_CHARS=150
TOP_K_RETRIEVAL=8

LLM_PROVIDER="openai"
LLM_MODEL="gpt-4.1-mini"
LLM_API_KEY=""
LLM_BASE_URL="https://api.openai.com/v1"
